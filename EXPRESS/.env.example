# =========================================================
# Server basics
# =========================================================
# MongoDB connection string used by the Express container.
MONGO_URI=mongodb://sigrae_admin:fredmenson-1234@mongodb:27017/docker-chat?authSource=admin

# Port exposed by the Express app inside Docker.
PORT=3000

# Frontend origin allowed to call this API.
# For local Docker dev, keep this pointed at your React app.
CLIENT_ORIGIN=http://localhost:5173


# =========================================================
# JWT auth
# =========================================================
# Secret used to sign and verify login tokens.
# Replace this with your own long random secret.
JWT_SECRET=replace_this_with_your_jwt_secret

# How long a user's login token remains valid.
# Examples: 1d, 7d, 12h, 30m
JWT_EXPIRES_IN=6h


# =========================================================
# Auth cookies
# =========================================================
# How long the auth cookie should stay in the browser, in milliseconds.
# 21600000 = 6 hours
JWT_COOKIE_MAX_AGE_MS=21600000

# Cookie SameSite policy.
# This controls when the browser is allowed to send your auth cookie.
#
# [strict]
#   Most restrictive option.
#   The cookie is only sent when the request clearly comes from the same site.
#   Good for maximum isolation, but it can break separate frontend/API deployments.
#
# [lax]
#   A balanced default for many apps.
#   Works well when the frontend and backend are truly same-site.
#   It is more forgiving than "strict", but still does not allow most cross-site cookie use.
#
# [none]
#   Allows the cookie to be sent on cross-site requests too.
#   Use this when your frontend and backend are deployed on different site contexts.
#   Browsers require COOKIE_SECURE=true when using "none".
#
# For setups like this:
# React:   https://website1.onrender.com
# Express: https://website2.onrender.com
# Render's shared onrender.com domain can behave like a cross-site setup for cookies,
# so "none" is usually the safer choice there.
COOKIE_SAME_SITE=lax # but lax should work for local development in Docker

# Set to true only when serving over HTTPS.
# For localhost development, keep this false.
# For your Render deployment, set this to true.
COOKIE_SECURE=false

# Optional: set this only if you need cookies shared across a real domain/subdomain setup.
# For your current Render deployment, leave this unset.
# Example: .yourdomain.com
# COOKIE_DOMAIN=your-domain.example


# =========================================================
# Primary AI provider: Gemini
# =========================================================
# Required if you want Gemini to generate DM responses.
GEMINI_API_KEY=your_gemini_api_key_here

# Default Gemini model used by the app.
GEMINI_MODEL=gemini-2.5-flash


# =========================================================
# Optional fallback AI provider: Groq
# =========================================================
# Used automatically if Gemini is unavailable and Groq is configured.
GROQ_API_KEY=your_groq_api_key_here

# Main Groq model to try first.
GROQ_MODEL=llama-3.3-70b-versatile

# Backup Groq models, tried in order if needed.
GROQ_FALLBACK_MODELS=openai/gpt-oss-20b,llama-3.1-8b-instant,openai/gpt-oss-120b
